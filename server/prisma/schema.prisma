generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  username     String    @unique
  displayName  String
  passwordHash String
  avatarColor  String    @default("#4A154B")
  status       String    @default("active") // "active" | "disabled" (soft delete)
  isAdmin      Boolean   @default(false)
  isOwner      Boolean   @default(false) // exactly one User has true at any time
  dndUntil     DateTime?
  dndScheduleEnabled Boolean @default(false)
  dndStart     String?
  dndEnd       String?
  createdAt    DateTime  @default(now())

  memberships Membership[]
  messages    Message[]
  attachments Attachment[]
  reactions   Reaction[]
  pushTokens  PushToken[]
  webPushSubscriptions WebPushSubscription[]
  invitations Invitation[]
  passwordResets PasswordReset[]
  bugReports  BugReport[]
  supportConversations SupportConversation[]
}

model Channel {
  id          String   @id @default(cuid())
  name        String?
  isDirect    Boolean  @default(false)
  isPrivate   Boolean  @default(false)
  isDefault   Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())

  memberships Membership[]
  messages    Message[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  joinedAt  DateTime @default(now())
  lastReadAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
}

model Message {
  id          String    @id @default(cuid())
  channelId   String
  authorId    String
  body        String
  // Plaintext copy used by the Postgres full-text search index. Stored in the
  // clear so `to_tsvector('french', searchableBody)` can be indexed; accepting
  // this trade-off rules out a later E2E rollout on the same channels.
  searchableBody String?
  createdAt   DateTime  @default(now())
  scheduledAt DateTime?
  delivered   Boolean   @default(true)
  editedAt    DateTime?
  parentId    String?

  channel     Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  attachments Attachment[]
  parent      Message?     @relation("MessageThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Message[]    @relation("MessageThread")
  reactions   Reaction[]

  @@index([channelId, createdAt])
  @@index([scheduledAt, delivered])
  @@index([parentId])
}

model Attachment {
  id          String   @id @default(cuid())
  messageId   String?
  uploadedBy  String
  filename    String
  mimeType    String
  size        Int      // plaintext size; the on-disk blob is larger when encrypted
  storagePath String   @unique
  encrypted   Boolean  @default(false) // pre-encryption rows stay false; new uploads are true
  createdAt   DateTime @default(now())
  // A bug-report screenshot lives here too: uploaded the same way (encrypted at
  // rest) but tied to a BugReport / SupportConversation instead of a chat Message.
  // Exactly one of messageId / bugReportId / supportConversationId is set; the
  // support link is transient (re-pointed to the BugReport on finalization).
  bugReportId           String?
  supportConversationId String?

  message Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)
  bugReport           BugReport?           @relation(fields: [bugReportId], references: [id], onDelete: Cascade)
  supportConversation SupportConversation? @relation(fields: [supportConversationId], references: [id], onDelete: SetNull)

  @@index([messageId])
  @@index([uploadedBy])
  @@index([bugReportId])
  @@index([supportConversationId])
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("android")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Web Push subscription (browser PWA, used for iOS via "Add to Home Screen"
// and any other modern browser). Same gating as PushToken in notifyMembers:
// only sent when the user has been idle on web/desktop for >= 10 min and is
// not in DnD. Endpoint is the natural unique key (one row per browser).
model WebPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String   // base64-url-encoded ECDH public key
  auth      String   // base64-url-encoded auth secret
  userAgent String?  // optional, useful for "Connected devices" UIs later
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Invitation {
  id         String    @id @default(cuid())
  email      String
  token      String    @unique
  invitedBy  String
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  acceptedAt DateTime?

  inviter User @relation(fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([email])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// In-app bug reports. Submitted by any authenticated user, consulted by admins
// in the Administration panel (DB-only — no email side-channel by design).
model BugReport {
  id          String   @id @default(cuid())
  // Nullable + SetNull: a report outlives its author (deleting a user keeps the
  // report, just unlinks it) so the admin backlog isn't silently pruned.
  userId      String?
  message     String
  // Free-form diagnostic header (app version, platform, server URL, socket state,
  // notif/push permission, screen, locale). JSON so the client shape can evolve.
  diagnostics Json?
  // Captured client log ring buffer (console warns/errors + app breadcrumbs).
  // Capped server-side (see routes/bugReports.js); never contains message bodies.
  logs        String?
  appVersion  String?
  platform    String?  // "web" | "pwa" | "desktop" | "android" | "ios"
  status      String   @default("open") // "open" | "closed"
  // Set once the report has been mirrored to a GitHub issue (best-effort, async).
  // Nullable: the GitHub bridge is optional (no token = no issue) and never blocks
  // submission. githubIssueNumber doubles as the idempotency guard.
  githubIssueNumber Int?
  githubIssueUrl    String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Screenshots/files the reporter attached (issue #96). Cascade-deleted with the
  // report so triaging it away leaves no orphan rows.
  attachments Attachment[]

  @@index([status, createdAt])
}

// In-app support conversation. When a user opens a ticket, instead of filing a
// raw report they chat with Claude (server-side, see src/anthropic.js) to refine
// the request; once the demand is clear Claude finalizes it, which creates a
// BugReport + GitHub issue (the existing signalement → claude-triage pipeline).
// The transcript is kept so the conversation can be resumed and audited.
model SupportConversation {
  id          String   @id @default(cuid())
  // Nullable + SetNull, same rationale as BugReport: outlives its author.
  userId      String?
  status      String   @default("open") // "open" | "submitted" | "abandoned"
  // Plain user/assistant text turns: [{ role: "user" | "assistant", content }].
  // The system prompt is server-only and never stored here.
  messages    Json
  // Diagnostics snapshot captured client-side when the ticket was opened — carried
  // through to the BugReport / issue on finalization (same shape as BugReport).
  appVersion  String?
  platform    String?
  diagnostics Json?
  logs        String?
  // Set on finalization: the BugReport row and the mirrored GitHub issue.
  bugReportId String?
  githubIssueNumber Int?
  githubIssueUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Attachments uploaded while composing the ticket; re-pointed to the BugReport
  // on finalization (see routes/support.js) so they ride along with the report.
  attachments Attachment[]

  @@index([userId, createdAt])
}
