{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chat",
  "version": "0.6.4",
  "identifier": "com.example.chat.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Chat",
        "width": 1100,
        "height": 760,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/claude-murgat/murgatchat/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZBMkNEOTVGQ0FGNDQ0QQpSV1JLUksvOGxjMmlCdlFmSytsZzlrSlc2bFRyWE9jVWY3eVJoWFIwSEsxckplRUZhUlVUamhBago="
    }
  }
}
