# dependencies
node_modules/
.pnp/
.pnp.js

# build outputs
web/dist/
web/.vite/
mobile/.expo/
mobile/dist/
mobile/web-build/
# Release binaries are published to GitHub Releases (CI on tag push), not committed.
dist/

# Tauri / Rust
web/src-tauri/target/
web/src-tauri/gen/
web/src-tauri/.cargo/
# Cargo.lock IS committed for reproducible CI builds (un-ignored).

# env & secrets
.env
.env.local
.env.*.local
# VAPID keys (auto-generated on first server start). Persisted in /data which
# should be mounted as a Docker volume so subscriptions don't break on restart.
server/data/
vapid.json

# logs / OS junk
*.log
.DS_Store
Thumbs.db

# test artifacts
server/.test-uploads/
e2e/test-results/
e2e/playwright-report/
e2e/blob-report/
e2e/.playwright/
