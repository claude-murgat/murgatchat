# Copiez ce fichier en .env (gitignoré) et renseignez les valeurs :
#   cp .env.example .env
# Le .env contient les secrets réels et ne doit JAMAIS être commité.

# --- Postgres ---
POSTGRES_USER=chat
POSTGRES_PASSWORD=change-me
POSTGRES_DB=chat

# --- Auth ---
# Secret de signature des JWT. Générez avec : openssl rand -hex 32
JWT_SECRET=

# --- Chiffrement des messages (AES-256-GCM) ---
# 64 caractères hexadécimaux = 32 octets. Générez UNE fois avec : openssl rand -hex 32
# /!\ Ne changez JAMAIS cette valeur une fois des messages chiffrés en base :
#     ils deviendraient définitivement illisibles ("[message non déchiffrable]").
MESSAGE_ENCRYPTION_KEY=

# --- Web (NON secret) ---
# URL de l'API, bakée dans le bundle web au moment du build. Mettez l'IP LAN de la
# machine qui héberge le serveur (ex. http://192.168.1.10:4000), sinon les autres
# machines du réseau ne pourront pas joindre l'API.
VITE_API_URL=http://localhost:4000

# --- Invitations / e-mail ---
# APP_URL = URL du web app, utilisée pour construire les liens d'invitation et de
# réinitialisation de mot de passe (?invite=<code> / ?reset=<code>). Mettez l'IP/host
# par lequel les invités accèdent au web app.
APP_URL=http://localhost:5173
# MAIL_FROM = adresse expéditrice (« From ») des e-mails d'invitation ET de
# réinitialisation de mot de passe. Format : « Nom affiché <adresse@domaine> »
# (ou juste « adresse@domaine »).
# /!\ Avec un relais type Brevo/SendGrid, cette adresse DOIT être un expéditeur
#     vérifié (domaine authentifié chez le fournisseur), sinon l'envoi est rejeté
#     ou classé en spam. Le défaut .local ci-dessous ne marche qu'en dev (Mailpit) ;
#     en prod, mettez une adresse de VOTRE domaine vérifié.
MAIL_FROM=Chat <no-reply@murgat-chat.local>

# --- Web Push (PWA, iOS via Add to Home Screen) ---
# VAPID keys signent les subscriptions push web. Au premier démarrage, le serveur
# en génère et persiste dans server/data/vapid.json (gitignoré, mappé sur un
# volume Docker). Surchargez ici si vous voulez les fournir explicitement (utile
# pour la rotation ou pour partager la même clé entre plusieurs instances).
# Générez avec : node -e "require('web-push').generateVAPIDKeys();" puis lisez la sortie.
# /!\ Changer les clés invalide TOUTES les subscriptions existantes — re-souscription
#     forcée pour tous les clients.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# VAPID_SUBJECT doit être mailto: ou https: per spec — défaut : mailto:admin@murgat-chat.local
VAPID_SUBJECT=

# --- Version checker (invite client à se mettre à jour) ---
# CLIENT_VERSION = version publiée annoncée aux clients via GET /version. Mettez-la
# à la version que vous venez de release (ex. 0.5.3) : les clients plus anciens
# afficheront une bannière (web: rafraîchir, desktop: télécharger l'installeur,
# Android: simple info). Laissée vide → fallback sur la version du serveur (basse)
# → aucune bannière (checker inactif).
CLIENT_VERSION=
# DOWNLOAD_URL = lien du bouton « Télécharger » (desktop) ; défaut = page Releases.
DOWNLOAD_URL=https://github.com/claude-murgat/murgatchat/releases/latest

# --- Sélecteur de GIF (GIPHY) ---
# GIPHY_API_KEY = clé d'API serveur pour la recherche de GIF (proxy /gifs). Créez
# une appli sur https://developers.giphy.com (clé beta instantanée). Laissée vide
# → le bouton GIF affiche « non configuré » et la recherche est désactivée.
# Le GIF choisi est ré-hébergé chiffré côté serveur (pas de hotlink).
GIPHY_API_KEY=
# GIF_RATING = filtre de contenu renvoyé par GIPHY : g | pg | pg-13 | r (défaut pg-13).
GIF_RATING=pg-13

# --- Pont signalements → GitHub (pipeline Claude) ---
# Quand un utilisateur envoie un signalement de bug, le serveur crée (en arrière-plan,
# best-effort) une issue GitHub labellisée « signalement » qui déclenche les workflows
# claude-triage / claude-fix. Laissé vide → fonctionnalité OFF (aucune issue créée),
# le signalement reste simplement en base comme avant.
# GITHUB_BUG_TOKEN = token avec la permission Issues: Read & write sur le dépôt cible.
#   Recommandé : PAT fine-grained limité à ce seul dépôt (idéalement un compte/bot dédié,
#   pas un PAT personnel large). Créez-le sur https://github.com/settings/personal-access-tokens
GITHUB_BUG_TOKEN=
# Dépôt destinataire des issues. Défauts = claude-murgat/murgatchat.
GITHUB_REPO_OWNER=claude-murgat
GITHUB_REPO_NAME=murgatchat

# --- Conversation de support in-app (API Anthropic) ---
# Quand un utilisateur clique « Signaler un bug », il dialogue avec Claude (côté
# serveur) pour préciser sa demande ; une fois claire, Claude finalise le ticket,
# ce qui crée le BugReport + l'issue GitHub « signalement » (pipeline ci-dessus).
# Laissé vide → chat OFF : le bouton retombe automatiquement sur l'envoi direct
# d'un signalement brut (comportement historique). Aucune clé n'est exposée au client.
# ANTHROPIC_API_KEY = clé API Anthropic (https://console.anthropic.com/).
ANTHROPIC_API_KEY=
# Modèle utilisé pour la conversation de support. Défaut = claude-opus-4-8.
SUPPORT_MODEL=claude-opus-4-8

# --- Notification in-app du pipeline (PR ouverte → message dans le chat) ---
# Le workflow claude-fix (runner LOCAL) appelle POST /support/notify avec ce
# secret partagé pour poster un message dans un salon d'équipe quand une PR est
# ouverte. Le MÊME secret doit être mis dans les secrets GitHub Actions
# (SUPPORT_NOTIFY_TOKEN). Vide → endpoint désactivé. Générez : openssl rand -hex 32
SUPPORT_NOTIFY_TOKEN=
# Salon d'équipe destinataire (créé à la volée s'il n'existe pas). Défaut = support-dev.
SUPPORT_NOTIFY_CHANNEL=support-dev

# --- SMTP ---
# En dev (docker-compose.yml par défaut), le serveur envoie les e-mails à Mailpit
# (service "mail", host=mail port=1025, UI http://localhost:8025) — pas besoin de
# configurer SMTP_* ici, c'est déjà câblé dans le compose.
#
# En prod, surchargez les SMTP_* ci-dessous. Exemple Brevo (smtp-relay.brevo.com) :
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=<votre login SMTP Brevo, ex. 9XXXXX@smtp-brevo.com>
#   SMTP_PASS=<votre clé SMTP Brevo (Settings → SMTP & API → SMTP), PAS le mot de passe du compte>
#   SMTP_SECURE=false        # 465=true (SSL direct), 587=false (STARTTLS)
#   SMTP_REQUIRE_TLS=true    # impose STARTTLS sur 587, recommandé
#
# Autres exemples :
#   - SendGrid       : host=smtp.sendgrid.net port=587 user=apikey pass=<API_KEY> require_tls=true
#   - OVH            : host=ssl0.ovh.net port=465 secure=true user=<email> pass=<password>
#   - Gmail SMTP relai : host=smtp.gmail.com port=587 require_tls=true user=<addr> pass=<app password>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
