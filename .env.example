# Copiez ce fichier en .env (gitignoré) et renseignez les valeurs :
#   cp .env.example .env
# Le .env contient les secrets réels et ne doit JAMAIS être commité.

# --- Postgres ---
POSTGRES_USER=chat
POSTGRES_PASSWORD=change-me
POSTGRES_DB=chat

# --- Auth ---
# Secret de signature des JWT. Générez avec : openssl rand -hex 32
JWT_SECRET=

# --- Chiffrement des messages (AES-256-GCM) ---
# 64 caractères hexadécimaux = 32 octets. Générez UNE fois avec : openssl rand -hex 32
# /!\ Ne changez JAMAIS cette valeur une fois des messages chiffrés en base :
#     ils deviendraient définitivement illisibles ("[message non déchiffrable]").
MESSAGE_ENCRYPTION_KEY=

# --- Web (NON secret) ---
# URL de l'API, bakée dans le bundle web au moment du build. Mettez l'IP LAN de la
# machine qui héberge le serveur (ex. http://192.168.1.10:4000), sinon les autres
# machines du réseau ne pourront pas joindre l'API.
VITE_API_URL=http://localhost:4000
