# Copiez ce fichier en .env (gitignoré) et renseignez les valeurs :
#   cp .env.example .env
# Le .env contient les secrets réels et ne doit JAMAIS être commité.

# --- Postgres ---
POSTGRES_USER=chat
POSTGRES_PASSWORD=change-me
POSTGRES_DB=chat

# --- Auth ---
# Secret de signature des JWT. Générez avec : openssl rand -hex 32
JWT_SECRET=

# --- Chiffrement des messages (AES-256-GCM) ---
# 64 caractères hexadécimaux = 32 octets. Générez UNE fois avec : openssl rand -hex 32
# /!\ Ne changez JAMAIS cette valeur une fois des messages chiffrés en base :
#     ils deviendraient définitivement illisibles ("[message non déchiffrable]").
MESSAGE_ENCRYPTION_KEY=

# --- Web (NON secret) ---
# URL de l'API, bakée dans le bundle web au moment du build. Mettez l'IP LAN de la
# machine qui héberge le serveur (ex. http://192.168.1.10:4000), sinon les autres
# machines du réseau ne pourront pas joindre l'API.
VITE_API_URL=http://localhost:4000

# --- Invitations / e-mail ---
# APP_URL = URL du web app, utilisée pour construire les liens d'invitation et de
# réinitialisation de mot de passe (?invite=<code> / ?reset=<code>). Mettez l'IP/host
# par lequel les invités accèdent au web app.
APP_URL=http://localhost:5173
MAIL_FROM=Chat <no-reply@murgat-chat.local>

# --- Version checker (invite client à se mettre à jour) ---
# CLIENT_VERSION = version publiée annoncée aux clients via GET /version. Mettez-la
# à la version que vous venez de release (ex. 0.5.3) : les clients plus anciens
# afficheront une bannière (web: rafraîchir, desktop: télécharger l'installeur,
# Android: simple info). Laissée vide → fallback sur la version du serveur (basse)
# → aucune bannière (checker inactif).
CLIENT_VERSION=
# DOWNLOAD_URL = lien du bouton « Télécharger » (desktop) ; défaut = page Releases.
DOWNLOAD_URL=https://github.com/claude-murgat/murgatchat/releases/latest

# --- SMTP ---
# En dev (docker-compose.yml par défaut), le serveur envoie les e-mails à Mailpit
# (service "mail", host=mail port=1025, UI http://localhost:8025) — pas besoin de
# configurer SMTP_* ici, c'est déjà câblé dans le compose.
#
# En prod, surchargez les SMTP_* ci-dessous. Exemple Brevo (smtp-relay.brevo.com) :
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=<votre login SMTP Brevo, ex. 9XXXXX@smtp-brevo.com>
#   SMTP_PASS=<votre clé SMTP Brevo (Settings → SMTP & API → SMTP), PAS le mot de passe du compte>
#   SMTP_SECURE=false        # 465=true (SSL direct), 587=false (STARTTLS)
#   SMTP_REQUIRE_TLS=true    # impose STARTTLS sur 587, recommandé
#
# Autres exemples :
#   - SendGrid       : host=smtp.sendgrid.net port=587 user=apikey pass=<API_KEY> require_tls=true
#   - OVH            : host=ssl0.ovh.net port=465 secure=true user=<email> pass=<password>
#   - Gmail SMTP relai : host=smtp.gmail.com port=587 require_tls=true user=<addr> pass=<app password>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
