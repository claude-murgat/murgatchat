{
  "expo": {
    "name": "Chat",
    "slug": "chat-murgat",
    "version": "0.6.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#3F0E40"
    },
    "android": {
      "package": "com.charlesmurgat.chat",
      "versionCode": 8,
      "adaptiveIcon": {
        "backgroundColor": "#3F0E40"
      }
    },
    "ios": {
      "bundleIdentifier": "com.charlesmurgat.chat",
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "extra": {
      "API_URL": "",
      "eas": {
        "projectId": "a237ea85-6e71-4e59-879b-8eb0e641938b"
      }
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "./plugins/withReleaseSigning"
    ]
  }
}
